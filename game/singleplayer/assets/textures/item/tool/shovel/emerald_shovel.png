  .chroma .cp { color: rgb(142, 192, 124); }
  .chroma .cpf { color: rgb(100, 155, 196); }
  .chroma .cs { color: rgb(144, 117, 205); }
  .chroma .dl { color: rgb(100, 155, 196); }
  .chroma .gd { color: rgb(255, 255, 255); background-color: rgb(95, 55, 55=
); }
  .chroma .ge { color: rgb(221, 238, 48); }
  .chroma .gh { color: rgb(255, 170, 16); }
  .chroma .gi { color: rgb(255, 255, 255); background-color: rgb(58, 82, 58=
