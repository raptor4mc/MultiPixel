.card-ghost { border-color: var(--color-secondary-dark-4) !important; borde=
r-style: dashed !important; background: none !important; }

.card-ghost * { opacity: 0; }

.tribute-container { position: absolute; top: 0px; left: 0px; height: auto;=
 max-height: 300px; max-width: 500px; overflow: auto; display: block; z-ind=
ex: 999999; }

.tribute-container ul { margin: 2px 0px 0px; padding: 0px; list-style: none=
; background: rgb(239, 239, 239); }

.tribute-container li { padding: 5px; cursor: pointer; }

.tribute-container li.highlight { background: rgb(221, 221, 221); }

.tribute-container li span { font-weight: 700; }

.tribute-container li.no-match { cursor: default; }

.tribute-container .menu-highlighted { font-weight: 700; }

.tribute-container { box-shadow: rgba(0, 0, 0, 0.25) 0px 0.25rem 0.5rem; bo=
rder-radius: var(--border-radius); }

