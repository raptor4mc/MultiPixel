:root { --color-nav-text: #ffffff; --color-nav-hover-bg: #00000014; --color=
-primary: #2185D0; --color-footer: #144B49; --color-footer-text: #fff; }

.following.bar, #navbar { background-color: var(--color-primary); border-bo=
ttom: none !important; }

#navbar-expand-toggle { --color-light-border: rgba(255,255,255,.5); --color=
-text-light: #fff; }

* { scrollbar-width: initial; scrollbar-color: initial; }

:root { --color-link: #0651ba; }

a, a:hover { color: var(--color-link); }

.ui.secondary.menu .active.item { background-color: var(--color-secondary-a=
lpha-30); }

footer a:hover { --color-text-light-2: #73CCC6; color: var(--color-text-lig=
ht-2) !important; }

:is(footer .language.button):hover, :is(footer .language.button):active, .a=
ctive.active:is(footer .language.button) { background-color: rgb(115, 204, =
198); }

:is(#navbar > .menu, #navbar > .menu .menu) > a, :is(#navbar > .menu, #navb=
ar > .menu .menu) > button, :is(#navbar > .menu, #navbar > .menu .menu) > d=
etails > summary { color: rgb(255, 255, 255); }

@media (prefers-color-scheme: dark) {
  .chroma .bp { color: rgb(250, 189, 47); }
  .chroma .c, .chroma .c1, .chroma .ch, .chroma .cm { color: rgb(119, 126, =
